        "view": "timeSeries",
        "stacked": true,
        "title": "Connections by state",
        "region": "REGION_PLACEHOLDER",
        "period": 60,
        "stat": "Average",
        "yAxis": { "left": { "min": 0 } },
        "metrics": [
          [{ "expression": "SEARCH('{PostgreSQL,ClusterName,InstanceId} MetricName=\"Connections.Active\" ClusterName=\"CLUSTER_PLACEHOLDER\"', 'Average', 10)", "label": "active", "id": "m1" }],
